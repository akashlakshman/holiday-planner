# AI Providers — add keys for the ones you want to enable
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# Default provider shown in UI: gemini | anthropic | openai
DEFAULT_AI_PROVIDER=gemini

# Amadeus (flights + hotels) — get free sandbox keys at developers.amadeus.com
AMADEUS_CLIENT_ID=your_amadeus_client_id_here
AMADEUS_CLIENT_SECRET=your_amadeus_client_secret_here
AMADEUS_BASE_URL=https://test.api.amadeus.com

# Supabase — get free project at supabase.com
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500,https://your-vercel-app.vercel.app
